<?xml version="1.0"?>
<Application>
  <Options CollectionsEditMode="Edit" />
  <ViewItems>
    <PropertyEditor Name="PropertyEditors">
      <RegisteredPropertyEditor PropertyType="System.Drawing.Color" EditorType="DevExpress.ExpressApp.Web.Editors.ASPx.ASPxColorPickerPropertyEditor" />
    </PropertyEditor>
  </ViewItems>
  <Views>
    <DetailView Id="CollectionRenderingNonPersistentCustom_DetailView">
      <Items>
        <PropertyEditor Id="CollectionItems" PropertyEditorType="Solution2.Module.Web.Editors.CollectionItemsPropertyEditor" />
        <PropertyEditor Id="DetailItems" PropertyEditorType="Solution2.Module.Web.Editors.DetailItemsPropertyEditor" />
      </Items>
    </DetailView>
  </Views>
</Application>
