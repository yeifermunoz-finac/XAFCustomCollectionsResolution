<?xml version="1.0"?>
<Application>
  <Options CollectionsEditMode="Edit" />
  <ViewItems>
    <PropertyEditor Name="PropertyEditors">
      <RegisteredPropertyEditor PropertyType="System.Drawing.Color" EditorType="DevExpress.ExpressApp.Web.Editors.ASPx.ASPxColorPickerPropertyEditor" />
    </PropertyEditor>
  </ViewItems>
  <Views>
    <DetailView Id="CollectionRenderingNonPersistentCustom_DetailView">
      <Items>
        <PropertyEditor Id="CollectionItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.CollectionItemsPropertyEditor">
          <MemberDetailView>
            <DetailView Id="CollectionRenderingNonPersistentCustom_CollectionItems_ListView_DetailView">
              <Items>
                <PropertyEditor Id="SubItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.SubCollectionItemsPropertyEditor" />
              </Items>
            </DetailView>
          </MemberDetailView>
        </PropertyEditor>
        <PropertyEditor Id="DetailItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.DetailItemsPropertyEditor" />
      </Items>
    </DetailView>
  </Views>
</Application>
