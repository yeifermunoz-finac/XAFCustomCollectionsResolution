<?xml version="1.0"?>
<Application>
  <Options CollectionsEditMode="View" />
  <ViewItems>
    <PropertyEditor Name="PropertyEditors">
      <RegisteredPropertyEditor PropertyType="System.Drawing.Color" EditorType="DevExpress.ExpressApp.Web.Editors.ASPx.ASPxColorPickerPropertyEditor" />
    </PropertyEditor>
  </ViewItems>
  <Views>
    <!-- Custom rendering: Apply custom ASPx editable collection property editor -->
    <DetailView Id="CollectionRenderingNonPersistentCustom_DetailView">
      <Items>
        <PropertyEditor Id="CollectionItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.CustomASPxEditableCollectionPropertyEditor" />
        <PropertyEditor Id="DetailItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.CustomASPxEditableCollectionPropertyEditor" />
      </Items>
    </DetailView>
    
    <!-- Custom rendering for persistent custom object -->
    <DetailView Id="CollectionRenderingPersistentCustom_DetailView">
      <Items>
        <PropertyEditor Id="CollectionItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.CustomASPxEditableCollectionPropertyEditor" />
        <PropertyEditor Id="DetailItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.CustomASPxEditableCollectionPropertyEditor" />
      </Items>
    </DetailView>

    <!-- Custom modal DetailView for persistent custom collection item -->
    <!-- Layout is now automatically cloned from CollectionItemPersistentCustom_DetailView -->
    <DetailView Id="CollectionItemPersistentCustom_Custom_DetailView" ClassName="CollectionsResolution.Module.BusinessObjects.CollectionRendering.CollectionItemPersistentCustom">
      <Items>
        <PropertyEditor Id="SubItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.CustomASPxEditableCollectionPropertyEditor" />
      </Items>
    </DetailView>
    
    <!-- Custom modal DetailView: Displayed in popup when user clicks "Details" button -->
    <!-- Layout is now automatically cloned from CollectionItemNonPersistent_DetailView -->
    <DetailView Id="CollectionItemNonPersistent_Custom_DetailView" ClassName="CollectionsResolution.Module.NonPersistentBusinessObjects.CollectionRendering.CollectionItemNonPersistent">
      <Items>
        <PropertyEditor Id="SubItems" PropertyEditorType="CollectionsResolution.Module.Web.Editors.CustomASPxEditableCollectionPropertyEditor" />
      </Items>
    </DetailView>

    <!-- Default rendering: Other views use default XAF editors (no configuration needed) -->
  </Views>
</Application>